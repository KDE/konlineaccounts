[Unit]
Description=KOnlineAccounts Service
PartOf=graphical-session.target
After=graphical-session.target

[Service]
ExecStart=@KDE_INSTALL_FULL_BINDIR@/konlineaccountsd
Type=exec
BusName=org.kde.KOnlineAccounts
TimeoutStopSec=5sec
Slice=background.slice
Restart=on-failure

[Install]
WantedBy=graphical-session.target
